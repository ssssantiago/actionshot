{
  "workflow_id": "conditional_branch",
  "description": "Process an expense report: if amount exceeds threshold, route to manager approval; otherwise auto-approve.",
  "inputs": [
    {"name": "expense_amount", "type": "string", "example": "1250.00"},
    {"name": "expense_category", "type": "string", "example": "Travel"}
  ],
  "outputs": [
    {"name": "result", "type": "string"}
  ],
  "steps": [
    {
      "id": 1,
      "op": "open_app",
      "target": "Expense Tracker - Desktop"
    },
    {
      "id": 2,
      "op": "click",
      "selector": {
        "primary": {"method": "uia_automation_id", "value": "btnNewExpense"},
        "tertiary": {"method": "ocr_anchor", "text": "New Expense"},
        "fallback": {"method": "coordinates", "x": 150, "y": 60},
        "label": "New Expense",
        "control_type": "Button"
      }
    },
    {
      "id": 3,
      "op": "fill_field",
      "selector": {
        "primary": {"method": "uia_automation_id", "value": "txtAmount"},
        "tertiary": {"method": "ocr_anchor", "text": "Amount ($)"},
        "fallback": {"method": "coordinates", "x": 400, "y": 180},
        "label": "Amount",
        "control_type": "Edit"
      },
      "value": "$expense_amount"
    },
    {
      "id": 4,
      "op": "select_option",
      "selector": {
        "primary": {"method": "uia_automation_id", "value": "cboCategory"},
        "tertiary": {"method": "ocr_anchor", "text": "Category"},
        "fallback": {"method": "coordinates", "x": 400, "y": 250},
        "label": "Category",
        "control_type": "ComboBox"
      },
      "option": "$expense_category"
    },
    {
      "id": 5,
      "op": "if_condition",
      "condition": "expense_amount > 1000",
      "description": "If expense exceeds $1000, route to manager approval",
      "then_steps": [
        {
          "id": 6,
          "op": "click",
          "selector": {
            "primary": {"method": "uia_automation_id", "value": "btnRequestApproval"},
            "tertiary": {"method": "ocr_anchor", "text": "Request Approval"},
            "fallback": {"method": "coordinates", "x": 400, "y": 400},
            "label": "Request Approval",
            "control_type": "Button"
          }
        }
      ],
      "else_steps": [
        {
          "id": 7,
          "op": "click",
          "selector": {
            "primary": {"method": "uia_automation_id", "value": "btnAutoApprove"},
            "tertiary": {"method": "ocr_anchor", "text": "Submit"},
            "fallback": {"method": "coordinates", "x": 400, "y": 400},
            "label": "Submit",
            "control_type": "Button"
          }
        }
      ]
    },
    {
      "id": 8,
      "op": "wait_for",
      "selector": {
        "primary": {"method": "uia_automation_id", "value": "lblConfirmation"},
        "tertiary": {"method": "ocr_anchor", "text": "Expense submitted"},
        "label": "Confirmation message",
        "control_type": "Text"
      },
      "timeout_ms": 10000
    }
  ],
  "assertions": []
}
